---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PmapRenderer from '../components/PmapRenderer.astro';
import { parsePmap } from '../utils/pmap-parser';
import fs from 'fs';
import path from 'path';

// Read and parse the about.pmap file
const pmapPath = path.join(process.cwd(), 'content', 'about.pmap');
const pmapContent = fs.readFileSync(pmapPath, 'utf-8');
const pageData = parsePmap(pmapContent);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageData.title || 'About'} description={pageData.description || ''} />
	</head>
	<body>
		<Header />
		<main class="about-page">
			<PmapRenderer sections={pageData.sections} />
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-page {
		text-align: center;
	}

	.about-page :global(h1),
	.about-page :global(h2),
	.about-page :global(h3),
	.about-page :global(h4),
	.about-page :global(h5),
	.about-page :global(h6),
	.about-page :global(p),
	.about-page :global(li) {
		margin-left: auto;
		margin-right: auto;
	}

	.about-page :global(ul) {
		list-style: none;
		padding: 0;
		margin: 0 auto 1.5em;
	}

	.about-page :global(li) {
		margin-bottom: 0.35em;
	}
</style>
