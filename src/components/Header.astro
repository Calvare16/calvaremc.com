<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #0a3b39;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
	}
	h2 {
		margin: 0;
		font-size: 1em;
		animation: none !important;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}

	h2 img {
		display: block;
		height: 36px;
		width: auto;
		max-width: 140px;
		object-fit: contain;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.internal-links {
		position: relative;
		display: flex;
		gap: 0;
	}

	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		text-decoration: none;
		position: relative;
		z-index: 1;
		transition: color 0.3s ease;
	}

	nav a.active {
		color: var(--accent);
		font-weight: bold;
	}

	/* Smooth gliding underline */
	.active-indicator {
		position: absolute;
		bottom: 0;
		height: 4px;
		background-color: var(--accent);
		border-radius: 2px;
		transition: left 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94),
					width 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
		z-index: 0;
	}

	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>

<script>
	function getIndicatorCoordinates(link: HTMLElement, container: HTMLElement) {
		const linkRect = link.getBoundingClientRect();
		const containerRect = container.getBoundingClientRect();
		return {
			left: linkRect.left - containerRect.left,
			width: linkRect.width,
		};
	}

	function animateIndicatorToCurrentPage() {
		const activeLink = document.querySelector('.internal-links a.active') as HTMLElement | null;
		const indicator = document.getElementById('activeIndicator');
		const internalLinks = document.querySelector('.internal-links') as HTMLElement | null;

		if (!activeLink || !indicator || !internalLinks) {
			return;
		}

		const otherLink = Array.from(internalLinks.querySelectorAll('a')).find(
			(link) => !link.classList.contains('active')
		) as HTMLElement | undefined;

		const activeCoordinates = getIndicatorCoordinates(activeLink, internalLinks);
		const indicatorTransition = 'left 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94), width 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';

		indicator.style.transition = 'none';
		if (otherLink) {
			const otherCoordinates = getIndicatorCoordinates(otherLink, internalLinks);
			indicator.style.left = otherCoordinates.left + 'px';
			indicator.style.width = otherCoordinates.width + 'px';
		}

		requestAnimationFrame(() => {
			indicator.style.transition = indicatorTransition;
			indicator.style.left = activeCoordinates.left + 'px';
			indicator.style.width = activeCoordinates.width + 'px';
		});
	}

	function updateActiveIndicator() {
		const activeLink = document.querySelector('.internal-links a.active') as HTMLElement | null;
		const indicator = document.getElementById('activeIndicator');
		const internalLinks = document.querySelector('.internal-links') as HTMLElement | null;

		if (activeLink && indicator && internalLinks) {
			const coordinates = getIndicatorCoordinates(activeLink, internalLinks);
			indicator.style.left = coordinates.left + 'px';
			indicator.style.width = coordinates.width + 'px';
		}
	}

	window.addEventListener('load', () => {
		setTimeout(animateIndicatorToCurrentPage, 10);
	});

	window.addEventListener('resize', updateActiveIndicator);

	document.addEventListener('astro:after-swap', () => {
		setTimeout(animateIndicatorToCurrentPage, 10);
	});

	document.querySelectorAll('.internal-links a').forEach((link) => {
		link.addEventListener('click', () => {
			setTimeout(animateIndicatorToCurrentPage, 10);
		});
	});
</script>
